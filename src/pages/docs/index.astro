---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allDocs = (await getCollection('docs')).sort((a, b) => a.data.order - b.data.order);
const groups = ['Getting Started', 'Node Operators', 'Reference', 'Developers'] as const;
const repoUrl = 'https://github.com/hempmillionaire/nono';

const card =
  'rounded-lg border border-line-soft bg-ink-900/60 backdrop-blur-sm transition-all hover:border-line-strong hover:-translate-y-0.5';
---
<Base
  title="Docs — NONO"
  description="Documentation for NONO: build a node, create a wallet, start mining, and understand the network parameters, emission curve, and genesis verification."
>
  <Header />
  <main>
    <section class="mx-auto max-w-6xl px-6 pt-20 pb-12 sm:pt-28">
      <p class="font-mono text-xs font-semibold uppercase tracking-widest text-nono-highlight">Docs</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-ink-100 sm:text-5xl">Documentation</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-300">
        NONO is a fair-launch, CPU-mined privacy currency forked from Monero: an independent network,
        its own emission curve, and no insider allocations. Privacy (RingCT, stealth addresses,
        bulletproofs+) and RandomX proof-of-work are inherited from Monero unchanged.
      </p>
      <p class="mt-4 max-w-2xl leading-relaxed text-ink-400">
        Start with
        <a href="/docs/getting-started" class="text-nono-highlight underline decoration-line-strong hover:decoration-nono-highlight">Getting started</a>
        if you just want to build a node and mine. Everything else here goes deeper on one topic —
        network parameters, the emission curve, privacy tooling, and how to verify NONO's no-premine
        claim yourself.
      </p>
    </section>

    {groups.map((group) => (
      <section class="border-t border-line-soft">
        <div class="mx-auto max-w-6xl px-6 py-14">
          <h2 class="font-mono text-sm font-semibold uppercase tracking-widest text-ink-400">{group}</h2>
          <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
            {allDocs.filter((d) => d.data.group === group).map((d) => (
              <a href={`/docs/${d.slug}`} class={`group block ${card} p-6`}>
                <h3 class="text-lg font-medium text-ink-100">{d.data.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-ink-400">{d.data.description}</p>
                <p class="mt-4 text-sm text-nono-highlight transition-colors group-hover:text-ink-100">Read &rarr;</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}
  </main>
  <Footer />
</Base>
