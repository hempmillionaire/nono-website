---
const repoUrl = 'https://github.com/hempmillionaire/nono';
const xUrl = 'https://x.com/nonochain';
const discordUrl = 'https://discord.gg/Tuwt6TAbJw';
const telegramUrl = 'https://t.me/nonoprivacy';
---
<footer class="border-t border-line-soft">
  <div class="mx-auto flex max-w-6xl flex-col gap-6 px-6 py-10 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-3">
      <span class="text-sm font-semibold tracking-tight text-ink-100">NONO<span class="text-nono-highlight">.</span></span>
      <span class="text-xs text-ink-400">Fair-launch RandomX privacy L1</span>
    </div>
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-ink-300">
      <a href="/docs" class="hover:text-ink-100 transition-colors">Docs</a>
      <a href={repoUrl} class="hover:text-ink-100 transition-colors">GitHub</a>
      <a href={discordUrl} class="hover:text-ink-100 transition-colors">Discord</a>
      <a href={telegramUrl} class="hover:text-ink-100 transition-colors">Telegram</a>
      <a href={xUrl} class="hover:text-ink-100 transition-colors">X</a>
      <a href="/#verify" class="hover:text-ink-100 transition-colors">Verify</a>
    </div>
  </div>
</footer>
