---
interface Props {
  eyebrow: string;
  title: string;
  sub?: string;
  center?: boolean;
}
const { eyebrow, title, sub, center = false } = Astro.props;
---
<div class={center ? 'text-center' : ''}>
  <p class="font-mono text-xs font-semibold uppercase tracking-widest text-nono-highlight">{eyebrow}</p>
  <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink-100 sm:text-4xl">{title}</h2>
  {sub && (
    <p class={`mt-4 text-base leading-relaxed text-ink-300 sm:text-lg ${center ? 'mx-auto max-w-2xl' : 'max-w-2xl'}`}>
      {sub}
    </p>
  )}
</div>
